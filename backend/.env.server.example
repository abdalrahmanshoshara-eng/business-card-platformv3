# Laptop server / Docker Compose configuration
# انسخ هذا الملف إلى backend/.env وعدل القيم حسب IP اللابتوب.

SECRET_KEY=change-this-to-a-long-random-secret
DEBUG=true
ALLOWED_HOSTS=127.0.0.1,localhost,0.0.0.0,YOUR_LAPTOP_IP,172.20.3.94

# Docker Compose uses the postgres service name internally.
DATABASE_URL=postgres://business_cards:business_cards@postgres:5432/business_cards

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://YOUR_LAPTOP_IP:3000,http://172.20.3.94:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://YOUR_LAPTOP_IP:3000,http://172.20.3.94:3000
CORS_ALLOW_ALL_ORIGINS=false

# Backward-compatible single key:
GEMINI_API_KEY=put-your-key-here
# Preferred multi-key setup. If non-empty, this list is used instead of GEMINI_API_KEY.
GEMINI_API_KEYS=put-key-1-here,put-key-2-here,put-key-3-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_REQUESTS_PER_CARD=3
GEMINI_KEY_COOLDOWN_SECONDS=60

ENABLE_WEBSITE_ENRICHMENT=true
ALLOW_GEMINI_WEBSITE_CLASSIFICATION=false
MEDIA_ROOT=media
