# ── Django Core ─────────────────────────────────────────────
SECRET_KEY=change-me-for-production
DEBUG=false
ALLOWED_HOSTS=127.0.0.1,localhost,0.0.0.0,YOUR_LAPTOP_IP

# ── Database ─────────────────────────────────────────────────
# Leave empty to use SQLite locally.
# For PostgreSQL: postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=

# ── CORS / CSRF ──────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://YOUR_LAPTOP_IP:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://YOUR_LAPTOP_IP:3000
CORS_ALLOW_ALL_ORIGINS=false

# ── Gemini AI ─────────────────────────────────────────────────
# Backward-compatible single key:
GEMINI_API_KEY=put-your-key-here
# Preferred multi-key setup. If non-empty, this list is used instead of GEMINI_API_KEY.
GEMINI_API_KEYS=put-key-1-here,put-key-2-here,put-key-3-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_REQUESTS_PER_CARD=3
GEMINI_KEY_COOLDOWN_SECONDS=60

# Website text fetching is deterministic and does not call Gemini by default.
ENABLE_WEBSITE_ENRICHMENT=true
# Keep false to avoid extra Gemini requests beyond card extraction.
ALLOW_GEMINI_WEBSITE_CLASSIFICATION=false

# ── Media ─────────────────────────────────────────────────────
MEDIA_ROOT=media

# ── Authentication / Sessions ────────────────────────────────
# Enable self-service registration (internal platform: keep false).
PUBLIC_REGISTRATION_ENABLED=false
# Set true only behind HTTPS (reverse proxy / local cert). HTTP LAN: false.
COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
SESSION_COOKIE_AGE=1209600
PASSWORD_RESET_TIMEOUT=86400
# Where password-reset links point (the SPA origin).
FRONTEND_BASE_URL=http://YOUR_LAPTOP_IP:3000

# Rate limits (DRF throttle format).
THROTTLE_LOGIN=10/min
THROTTLE_REGISTER=5/min
THROTTLE_FORGOT=5/min

# ── Email (password reset) ───────────────────────────────────
# Default is console. For real mail use SMTP backend + EMAIL_* below.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=false
DEFAULT_FROM_EMAIL=no-reply@example.local

# ── Uploads ──────────────────────────────────────────────────
MAX_UPLOAD_IMAGE_MB=10
