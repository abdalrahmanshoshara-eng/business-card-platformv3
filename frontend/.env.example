# ============================================================
# Frontend Environment Variables
# ============================================================

# Base path for API calls FROM THE BROWSER.
# Always keep /api — Next.js rewrites proxy this to Django.
NEXT_PUBLIC_API_BASE_URL=/api

# Django backend URL used by Next.js SERVER (for rewrites).
# Local dev:    http://127.0.0.1:8000
# Docker:       http://backend:8000      (Docker internal DNS — set as build arg)
# Production:   https://YOUR_APP.onrender.com
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000
